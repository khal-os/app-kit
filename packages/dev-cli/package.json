{
	"name": "@khal-os/dev-cli",
	"version": "1.0.0",
	"description": "Khal OS developer CLI — scaffolding and QA tools",
	"type": "module",
	"bin": {
		"khal-dev": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"typecheck": "tsc --noEmit",
		"dev": "tsx src/index.ts"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/khal-os/app-kit.git",
		"directory": "packages/dev-cli"
	},
	"dependencies": {
		"@nats-io/transport-node": "^3.3.1",
		"chalk": "^5.4.1",
		"commander": "^12.0.0",
		"ws": "^8.0.0"
	},
	"devDependencies": {
		"@types/ws": "^8.0.0",
		"tsup": "^8.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0"
	}
}
