# HELLO Voice Engine — Required API Keys
# Copy to .env and fill in values

# Google Gemini (required for voice model)
GEMINI_API_KEY=

# Twilio (required for phone calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# NATS (defaults to localhost)
NATS_URL=nats://localhost:4222

# Voice Engine Server
HELLO_VOICE_PORT=7860

# Public WebSocket URL for Twilio callbacks
# Twilio needs to reach this URL to stream audio after placing a call.
# For development: use ngrok (ngrok http 7860) and set to wss://<id>.ngrok.io
# For production: configure Caddy to reverse_proxy /twilio/* to localhost:7860
HELLO_WS_PUBLIC_URL=
