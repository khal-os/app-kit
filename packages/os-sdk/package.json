{
	"name": "@khal-os/sdk",
	"version": "1.0.10",
	"type": "module",
	"private": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./app": {
			"import": {
				"types": "./dist/app/index.d.ts",
				"default": "./dist/app/index.js"
			},
			"require": {
				"types": "./dist/app/index.d.cts",
				"default": "./dist/app/index.cjs"
			}
		},
		"./app/roles": {
			"import": {
				"types": "./dist/app/roles.d.ts",
				"default": "./dist/app/roles.js"
			},
			"require": {
				"types": "./dist/app/roles.d.cts",
				"default": "./dist/app/roles.cjs"
			}
		},
		"./app/registry": {
			"import": {
				"types": "./dist/app/app-registry.d.ts",
				"default": "./dist/app/app-registry.js"
			},
			"require": {
				"types": "./dist/app/app-registry.d.cts",
				"default": "./dist/app/app-registry.cjs"
			}
		},
		"./app/subjects": {
			"import": {
				"types": "./dist/app/subjects.d.ts",
				"default": "./dist/app/subjects.js"
			},
			"require": {
				"types": "./dist/app/subjects.d.cts",
				"default": "./dist/app/subjects.cjs"
			}
		},
		"./runtime": {
			"import": {
				"types": "./dist/runtime/index.d.ts",
				"default": "./dist/runtime/index.js"
			},
			"require": {
				"types": "./dist/runtime/index.d.cts",
				"default": "./dist/runtime/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"prepublishOnly": "pnpm run build"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"dependencies": {
		"@khal-os/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/khal-os/app-kit.git",
		"directory": "packages/os-sdk"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "Elastic-2.0"
}
