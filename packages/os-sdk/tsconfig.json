{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"incremental": true,
		"composite": true,
		"outDir": "./dist",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
