{
	"name": "@khal-os/{{packageName}}",
	"version": "0.0.1",
	"private": true,
	"main": "./manifest.ts",
	"exports": {
		".": "./manifest.ts",
		"./components": "./components.ts",
		"./views/*": "./views/*"
	},
	"genieOs": {
		"services": [
			{
				"name": "{{name}}",
				"entry": "./views/{{name}}/service/index.ts",
				"runtime": "node"
			}
		]
	},
	"peerDependencies": {
		"react": ">=19"
	}
}
