{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"strict": true,
		"noEmit": false,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"incremental": false,
		"outDir": "./dist",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
